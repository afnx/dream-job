generator client {
  provider = "prisma-client-js"
  output   = "generated/prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id          Int      @id @default(autoincrement())
  title       String
  company     String
  location    String
  description String
  postDate    DateTime
  link        String
  rank        Float    @default(0.0)
  createdAt   DateTime @default(now())
}
